STYLE_ROOT=C:\Duna\Style-Suite-Test

SUPABASE_URL=https://supabase.lipoout.com

SUPABASE_SERVICE_ROLE_KEY=

# Empresa hub Style (instancia VFP única). Ventas/facturas de AMBAS empresas Suite
# se encolan en outbox/cola con este company_id; origen en payload.suite_company_id.
COMPANY_ID=5d72535b-4e2c-4a5b-9900-e6c5a85f2ce4

POLL_MS=1500

INBOUND_POLL_MS=1500

INBOUND_BATCH=50

INBOUND_WORKER_TRIGGER=1

INBOUND_WORKER_MIN_INTERVAL_MS=8000

INBOUND_WORKER_STALE_MS=15000

INBOUND_DIR=C:\Duna\Style-Suite-Test\sync\inbound

INBOUND_ACK_DIR=C:\Duna\Style-Suite-Test\sync\inbound_ack

ARCHIVE_DIR=C:\Duna\Style-Suite-Test\sync\archive

DEADLETTER_DIR=C:\Duna\Style-Suite-Test\sync\deadletter

