# Copiar a .env y rellenar con la clave anon del proyecto (Settings → API).
VITE_SUPABASE_URL="https://supabase.lipoout.com"
VITE_SUPABASE_ANON_KEY=""

# Immich (solo servidor Supabase / Edge Function immich-proxy, NO en el frontend)
# IMMICH_BASE_URL=http://192.168.99.110:2283
# IMMICH_API_KEY=
# Configurar en 110: .\scripts\configure-immich-edge.ps1 -ApiKey "..."

# Ingest báscula MorphoScan (Edge Function scale-ingest; secreto en contenedor edge, no en Vite)
# SCALE_INGEST_SECRET=
# Configurar en 110: .\scripts\configure-scale-ingest-edge.ps1 -Secret "..."

# SmartPSS Lite → MySQL de eventos (Edge Function smartpss-events; NO en Vite)
# SMARTPSS_MYSQL_HOST=192.168.99.110
# SMARTPSS_MYSQL_PORT=3306
# SMARTPSS_MYSQL_USER=root
# SMARTPSS_MYSQL_PASSWORD=
# SMARTPSS_MYSQL_DATABASE=smartpss_events
# SMARTPSS_MYSQL_TABLE=AttendanceRecordInfo
# Configurar en 110: .\scripts\configure-smartpss-edge.ps1 -Password "..."

# Opcional: Postgres directo (migraciones, COPY al esquema legacy). Solo en local.
# SUPABASE_DB_URL=postgresql://postgres:PASSWORD@192.168.x.x:5433/postgres

# Import DBF legacy (cp1252 = Windows ES; si caracteres raros: latin-1 o cp850)
# LEGACY_DBF_DIR=E:\dbf
# LEGACY_DBF_ENCODING=cp1252
# Tras migración wave2: importar todas las tablas del esquema legacy (no solo las 8 iniciales).
# LEGACY_IMPORT_SCOPE=all
# Generar SQL wave2 desde ESTRUCTURA_COMPLETA_LIPOOUT.txt (ruta por defecto en scripts/legacy_structure.py):
# STRUCTURA_TXT=E:\APP Lipoout\dbf\ESTRUCTURA_COMPLETA_LIPOOUT.txt

# Promoción legacy → Suite (company_id por defecto en scripts/legacy_company.py)
# LEGACY_COMPANY_ID=5d72535b-4e2c-4a5b-9900-e6c5a85f2ce4
# PROMOTE_COMPANY_ID=5d72535b-4e2c-4a5b-9900-e6c5a85f2ce4
# PROMOTE_MERGE_CONSECUTIVE=1
# PROMOTE_MERGE_GAP_MINUTES=15
# TIPINC de borrado (última fila por IDPLAN no genera cita). Por defecto el script usa BORRAR (Style).
# Varios: PROMOTE_EXCLUDE_TIPINC=BORRAR,OTRO
# Desactivar exclusión: PROMOTE_EXCLUDE_TIPINC=
# Día corte: exportar DBF desde Dunasoft y ejecutar pipeline completo:
# LEGACY_IMPORT_SCOPE=all
# LEGACY_DBF_DIR=E:\dbf
# IMPORT_BATCH=2026-05-27-corte
# python scripts/legacy_import_pipeline.py --mode refresh
# python scripts/legacy_import_pipeline.py --mode full          # incluye catálogo/clientes/bonos
# python scripts/legacy_import_pipeline.py --mode staging       # solo legacy.*
# python scripts/legacy_import_pipeline.py --dry-run --mode refresh
